[Unit]
Description=todo-list-mcp backend service
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/todo-list-mcp/current/server
ExecStart=/usr/bin/node /opt/todo-list-mcp/current/server/dist/app.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
